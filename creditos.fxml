<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background: #1a1a2e; -fx-background-color: #1a1a2e;"
            xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CreditosController">

    <VBox alignment="CENTER" spacing="8"
          style="-fx-background-color: #1a1a2e;"
          prefWidth="900">

        <padding><Insets top="40" bottom="40" left="80" right="80"/></padding>

        <!-- Título -->
        <Label text="⚔  CROWNS"
               style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;"/>
        <Label text="Jogo de Cartas Estratégico"
               style="-fx-font-size: 14px; -fx-text-fill: #aaaaaa; -fx-font-style: italic;"/>

        <Label text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
               style="-fx-text-fill: #444444;"/>

        <!-- Desenvolvedores -->
        <Label text="👥  Desenvolvedores"
               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;"/>
        <Label fx:id="labelAluno1"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>
        <Label fx:id="labelAluno2"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>

        <Label text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
               style="-fx-text-fill: #444444;"/>

        <!-- Disciplina -->
        <Label text="🎓  Disciplina"
               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;"/>
        <Label fx:id="labelDisciplina"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>

        <Label text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
               style="-fx-text-fill: #444444;"/>

        <!-- Referências -->
        <Label text="🎮  Referências"
               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;"/>
        <Label fx:id="labelRef1"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>
        <Label fx:id="labelRef2"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>

        <Label text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
               style="-fx-text-fill: #444444;"/>

        <!-- Tecnologias -->
        <Label text="🛠  Tecnologias Utilizadas"
               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;"/>
        <Label fx:id="labelTec1"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>
        <Label fx:id="labelTec2"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>
        <Label fx:id="labelTec3"
               style="-fx-font-size: 13px; -fx-text-fill: #dddddd;"/>

        <Label text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
               style="-fx-text-fill: #444444;"/>

        <!-- Versão -->
        <Label fx:id="labelVersao"
               style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>

        <!-- Espaço antes do botão -->
        <Region prefHeight="10"/>

        <!-- Botão Voltar -->
        <Button text="← Voltar ao Menu" onAction="#aoVoltar"
                style="-fx-background-color: #e2b96f; -fx-text-fill: #1a1a2e;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 9 28 9 28; -fx-cursor: hand;
                       -fx-background-radius: 6;"/>

    </VBox>
</ScrollPane>
