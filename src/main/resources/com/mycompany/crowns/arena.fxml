<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ArenaController">

    <padding><Insets bottom="16" left="24" right="24" top="16" /></padding>

    <!-- Cabeçalho: nome do inimigo e arena -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label fx:id="lblArena" style="-fx-text-fill: #e2b96f; -fx-font-size: 18px; -fx-font-weight: bold;" />
        <Label fx:id="lblInimigo" style="-fx-text-fill: #ff6b6b; -fx-font-size: 16px;" />
    </HBox>

    <!-- Área do Inimigo -->
    <VBox spacing="6" style="-fx-background-color: #2a1a1a; -fx-background-radius: 8; -fx-padding: 12;">
        <Label style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;" text=" INIMIGO" />
        <HBox fx:id="cartasInimigo" alignment="CENTER_LEFT" spacing="8" />
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label style="-fx-text-fill: #aaa;" text="HP:" />
            <ProgressBar fx:id="barraHpInimigo" prefHeight="16" prefWidth="300" style="-fx-accent: #ff4444;" />
            <Label fx:id="lblHpInimigo" style="-fx-text-fill: #ff6b6b;" />
        </HBox>
    </VBox>

    <!-- Log de batalha -->
    <TextArea fx:id="logBatalha" editable="false" prefHeight="120" style="-fx-control-inner-background: #12122a; -fx-text-fill: #cccccc;                      -fx-font-size: 12px; -fx-border-color: #333;" wrapText="true" />

    <!-- Área do Jogador -->
    <VBox spacing="6" style="-fx-background-color: #1a2a1a; -fx-background-radius: 8; -fx-padding: 12;">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label style="-fx-text-fill: #aaa;" text="HP:" />
            <ProgressBar fx:id="barraHpJogador" prefHeight="16" prefWidth="300" style="-fx-accent: #44ff44;" />
            <Label fx:id="lblHpJogador" style="-fx-text-fill: #88ff88;" />
            <Label style="-fx-text-fill: #aaa;" text="  ELIXIR:" />
            <ProgressBar fx:id="barraElixir" prefHeight="16" prefWidth="150" style="-fx-accent: #aa44ff;" />
            <Label fx:id="lblElixir" style="-fx-text-fill: #cc88ff;" />
        </HBox>
        <Label style="-fx-text-fill: #88ff88; -fx-font-size: 13px;" text=" SUAS CARTAS — clique para usar" />
        <HBox fx:id="cartasJogador" alignment="CENTER" spacing="10" />
    </VBox>

    <!-- Botões de ação -->
    <HBox alignment="CENTER" spacing="12">
        <Button fx:id="btnPassarTurno" onAction="#aoPassarTurno" prefHeight="40" prefWidth="160" style="-fx-background-color: #3a3a5a; -fx-text-fill: white;                        -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;" text=" Passar Turno" />
        <Button fx:id="btnAbrirDeck" onAction="#aoAbrirDeck" prefHeight="40" prefWidth="140" style="-fx-background-color: #2a2a4a; -fx-text-fill: #aaa;                        -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" text="Ver Deck" />
        <Button fx:id="btnVoltar" onAction="#aoVoltarMenu" prefHeight="40" prefWidth="120" style="-fx-background-color: #4a1a1a; -fx-text-fill: #ff6b6b;                        -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" text=" Menu" />
    </HBox>

    <Label fx:id="lblTurno" alignment="CENTER" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
</VBox>
