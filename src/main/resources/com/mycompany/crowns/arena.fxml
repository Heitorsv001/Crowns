<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ArenaController"
      spacing="10"
      style="-fx-background-color: #1a1a2e;">

    <padding><Insets top="16" bottom="16" left="24" right="24"/></padding>

    <!-- Cabeçalho: nome do inimigo e arena -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label fx:id="lblArena"
               style="-fx-text-fill: #e2b96f; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label fx:id="lblInimigo"
               style="-fx-text-fill: #ff6b6b; -fx-font-size: 16px;"/>
    </HBox>

    <!-- Área do Inimigo -->
    <VBox spacing="6" style="-fx-background-color: #2a1a1a; -fx-background-radius: 8; -fx-padding: 12;">
        <Label text="⚔ INIMIGO" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;"/>
        <HBox fx:id="cartasInimigo" spacing="8" alignment="CENTER_LEFT"/>
        <HBox spacing="16" alignment="CENTER_LEFT">
            <Label text="HP:" style="-fx-text-fill: #aaa;"/>
            <ProgressBar fx:id="barraHpInimigo" prefWidth="300" prefHeight="16"
                         style="-fx-accent: #ff4444;"/>
            <Label fx:id="lblHpInimigo" style="-fx-text-fill: #ff6b6b;"/>
        </HBox>
    </VBox>

    <!-- Log de batalha -->
    <TextArea fx:id="logBatalha"
              prefHeight="120" editable="false" wrapText="true"
              style="-fx-control-inner-background: #12122a; -fx-text-fill: #cccccc;
                     -fx-font-size: 12px; -fx-border-color: #333;"/>

    <!-- Área do Jogador -->
    <VBox spacing="6" style="-fx-background-color: #1a2a1a; -fx-background-radius: 8; -fx-padding: 12;">
        <HBox spacing="16" alignment="CENTER_LEFT">
            <Label text="HP:" style="-fx-text-fill: #aaa;"/>
            <ProgressBar fx:id="barraHpJogador" prefWidth="300" prefHeight="16"
                         style="-fx-accent: #44ff44;"/>
            <Label fx:id="lblHpJogador" style="-fx-text-fill: #88ff88;"/>
            <Label text="  ELIXIR:" style="-fx-text-fill: #aaa;"/>
            <ProgressBar fx:id="barraElixir" prefWidth="150" prefHeight="16"
                         style="-fx-accent: #aa44ff;"/>
            <Label fx:id="lblElixir" style="-fx-text-fill: #cc88ff;"/>
        </HBox>
        <Label text="🂡 SUAS CARTAS — clique para usar"
               style="-fx-text-fill: #88ff88; -fx-font-size: 13px;"/>
        <HBox fx:id="cartasJogador" spacing="10" alignment="CENTER"/>
    </VBox>

    <!-- Botões de ação -->
    <HBox spacing="12" alignment="CENTER">
        <Button fx:id="btnPassarTurno" text="⏭ Passar Turno"
                onAction="#aoPassarTurno"
                prefWidth="160" prefHeight="40"
                style="-fx-background-color: #3a3a5a; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button fx:id="btnAbrirDeck" text="🃏 Ver Deck"
                onAction="#aoAbrirDeck"
                prefWidth="140" prefHeight="40"
                style="-fx-background-color: #2a2a4a; -fx-text-fill: #aaa;
                       -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button fx:id="btnVoltar" text="← Menu"
                onAction="#aoVoltarMenu"
                prefWidth="120" prefHeight="40"
                style="-fx-background-color: #4a1a1a; -fx-text-fill: #ff6b6b;
                       -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <Label fx:id="lblTurno"
           style="-fx-text-fill: #666; -fx-font-size: 12px;"
           alignment="CENTER"/>
</VBox>
