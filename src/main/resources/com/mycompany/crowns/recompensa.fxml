<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="24"
      xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.RecompensaController"
      style="-fx-background-color: #1a1a2e;">

    <padding><Insets top="60" bottom="60" left="80" right="80"/></padding>

    <Label text="🏆 VITÓRIA!" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;"/>

    <Label fx:id="lblMensagem" wrapText="true" textAlignment="CENTER"
           style="-fx-font-size: 16px; -fx-text-fill: #cccccc;" maxWidth="500"/>

    <VBox spacing="8" alignment="CENTER"
          style="-fx-background-color: #2a2a4a; -fx-background-radius: 10; -fx-padding: 20;">
        <Label fx:id="lblMoedas" style="-fx-font-size: 22px; -fx-text-fill: #e2b96f;"/>
        <Label fx:id="lblCartaBonus" style="-fx-font-size: 16px; -fx-text-fill: #88ff88;"/>
    </VBox>

    <HBox spacing="16" alignment="CENTER">
        <Button fx:id="btnContinuar" text="▶ Próxima Arena"
                onAction="#aoContinuar" prefWidth="200" prefHeight="48"
                style="-fx-background-color: #e2b96f; -fx-text-fill: #1a1a2e;
                       -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="🏪 Ir para Loja" onAction="#aoIrLoja"
                prefWidth="180" prefHeight="48"
                style="-fx-background-color: #2a2a4a; -fx-text-fill: #cccccc;
                       -fx-font-size: 14px; -fx-background-radius: 8;
                       -fx-border-color: #555; -fx-cursor: hand;"/>
    </HBox>
</VBox>
