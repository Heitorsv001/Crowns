<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.HistoricoController">
    <padding><Insets bottom="40" left="60" right="60" top="40" /></padding>
    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;" text="📜 Histórico de Runs" />
    <Label fx:id="lblEstatisticas" style="-fx-font-size: 15px; -fx-text-fill: #cccccc;" />
    <TextArea fx:id="areaHistorico" editable="false" prefHeight="300" prefWidth="500" style="-fx-control-inner-background: #12122a; -fx-text-fill: #ccc;" wrapText="true" />
    <Button onAction="#aoVoltar" prefHeight="40" prefWidth="160" style="-fx-background-color: #2a2a4a; -fx-text-fill: #ccc;                    -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;" text=" Voltar" />
</VBox>
