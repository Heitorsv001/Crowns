<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.PrimaryController"
      style="-fx-background-color: #1a1a2e;">

    <padding><Insets top="60" bottom="60" left="80" right="80"/></padding>

    <Label text="⚔ CROWNS ⚔"
           style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;"/>

    <Label text="Jogo de Cartas Estratégico"
           style="-fx-font-size: 16px; -fx-text-fill: #aaaaaa;"/>

    <VBox spacing="8" alignment="CENTER" maxWidth="300">
        <Label text="Digite seu nome:"
               style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"/>
        <TextField fx:id="campoNome"
                   promptText="Seu nome aqui..."
                   maxWidth="240"
                   style="-fx-background-color: #2a2a4a; -fx-text-fill: white;
                          -fx-border-color: #e2b96f; -fx-border-radius: 4;
                          -fx-background-radius: 4; -fx-font-size: 14px;"/>
    </VBox>

    <Button fx:id="btnJogar" text="▶  JOGAR"
            onAction="#aoClicarJogar"
            prefWidth="240" prefHeight="48"
            style="-fx-background-color: #e2b96f; -fx-text-fill: #1a1a2e;
                   -fx-font-size: 16px; -fx-font-weight: bold;
                   -fx-background-radius: 8; -fx-cursor: hand;"/>

    <Button fx:id="btnHistorico" text="📜  HISTÓRICO"
            onAction="#aoClicarHistorico"
            prefWidth="240" prefHeight="40"
            style="-fx-background-color: #2a2a4a; -fx-text-fill: #cccccc;
                   -fx-font-size: 14px; -fx-background-radius: 8;
                   -fx-border-color: #555; -fx-cursor: hand;"/>

    <Button fx:id="btnCreditos" text="ℹ  CRÉDITOS"
            onAction="#aoClicarCreditos"
            prefWidth="240" prefHeight="40"
            style="-fx-background-color: #2a2a4a; -fx-text-fill: #cccccc;
                   -fx-font-size: 14px; -fx-background-radius: 8;
                   -fx-border-color: #555; -fx-cursor: hand;"/>

    <Button fx:id="btnSair" text="✖  SAIR"
            onAction="#aoClicarSair"
            prefWidth="240" prefHeight="40"
            style="-fx-background-color: #4a1a1a; -fx-text-fill: #ff6b6b;
                   -fx-font-size: 14px; -fx-background-radius: 8;
                   -fx-cursor: hand;"/>

    <Label fx:id="lblErro" text=""
           style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;"/>
</VBox>
