<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PrimaryController">

    <padding><Insets bottom="60" left="80" right="80" top="60" /></padding>

    <Label style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;" text="CROWNS " />

    <VBox alignment="CENTER" maxWidth="300" spacing="8">
        <Label style="-fx-text-fill: #cccccc; -fx-font-size: 14px;" text="Digite seu nome:" />
        <TextField fx:id="campoNome" maxWidth="240" promptText="Seu nome aqui..." style="-fx-background-color: #2a2a4a; -fx-text-fill: white;                           -fx-border-color: #e2b96f; -fx-border-radius: 4;                           -fx-background-radius: 4; -fx-font-size: 14px;" />
    </VBox>

    <Button fx:id="btnJogar" onAction="#aoClicarJogar" prefHeight="48" prefWidth="240" style="-fx-background-color: #e2b96f; -fx-text-fill: #1a1a2e;                    -fx-font-size: 16px; -fx-font-weight: bold;                    -fx-background-radius: 8; -fx-cursor: hand;" text="▶  JOGAR" />

    <Button fx:id="btnHistorico" onAction="#aoClicarHistorico" prefHeight="40" prefWidth="240" style="-fx-background-color: #2a2a4a; -fx-text-fill: #cccccc;                    -fx-font-size: 14px; -fx-background-radius: 8;                    -fx-border-color: #555; -fx-cursor: hand;" text="📜  HISTÓRICO" />

    <Button fx:id="btnCreditos" onAction="#aoClicarCreditos" prefHeight="40" prefWidth="240" style="-fx-background-color: #2a2a4a; -fx-text-fill: #cccccc;                    -fx-font-size: 14px; -fx-background-radius: 8;                    -fx-border-color: #555; -fx-cursor: hand;" text="ℹ  CRÉDITOS" />

    <Button fx:id="btnSair" onAction="#aoClicarSair" prefHeight="40" prefWidth="240" style="-fx-background-color: #4a1a1a; -fx-text-fill: #ff6b6b;                    -fx-font-size: 14px; -fx-background-radius: 8;                    -fx-cursor: hand;" text="✖  SAIR" />

    <Label fx:id="lblErro" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;" text="" />
</VBox>
